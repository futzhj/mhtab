#include <windows.h>
#include "resource.h"

/* RC 源文件按 UTF-8 解析（与编辑器保存编码一致），中文字符串正确编译 */
#pragma code_page(65001)

LANGUAGE LANG_CHINESE, SUBLANG_CHINESE_SIMPLIFIED

/* ============================================================
 * Version Info
 * ============================================================ */
VS_VERSION_INFO VERSIONINFO
 FILEVERSION    0,1,0,0
 PRODUCTVERSION 0,1,0,0
 FILEFLAGSMASK  0x3fL
#ifdef _DEBUG
 FILEFLAGS      VS_FF_DEBUG
#else
 FILEFLAGS      0x0L
#endif
 FILEOS         VOS_NT_WINDOWS32
 FILETYPE       VFT_APP
 FILESUBTYPE    0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "mhtabx contributors"
            VALUE "FileDescription",  "mhtabx - Multi-process Tab Container"
            VALUE "FileVersion",      "0.1.0.0"
            VALUE "InternalName",     "mhtabx"
            VALUE "LegalCopyright",   "MIT License"
            VALUE "OriginalFilename", "mhtabx.exe"
            VALUE "ProductName",      "mhtabx"
            VALUE "ProductVersion",   "0.1.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END

/* ============================================================
 * Icon (W1: 未提供真实图标，占位)
 * 提供真图标后取消注释，放到 src/resource/icons/app.ico
 * ============================================================ */
/* IDI_APP_ICON ICON "icons/app.ico" */

/* ============================================================
 * Manifest (由 CMake /MANIFESTDEPENDENCY 链接器参数提供，
 * 不需要在此显式声明)
 * ============================================================ */

/* ============================================================
 * 主菜单
 * ============================================================ */
IDR_MAINMENU MENU
BEGIN
    POPUP "文件(&F)"
    BEGIN
        MENUITEM "新建 Tab(&N)\tCtrl+N",        ID_FILE_NEW
        MENUITEM "关闭当前 Tab(&W)\tCtrl+W",    ID_FILE_CLOSE_TAB
        MENUITEM SEPARATOR
        MENUITEM "退出(&X)\tAlt+F4",            ID_FILE_EXIT
    END
    POPUP "标签(&T)"
    BEGIN
        MENUITEM "下一个(&N)\tCtrl+Tab",         ID_TAB_NEXT
        MENUITEM "上一个(&P)\tCtrl+Shift+Tab",   ID_TAB_PREV
        MENUITEM SEPARATOR
        MENUITEM "重命名(&R)\tF2",               ID_TAB_RENAME
    END
    POPUP "帮助(&H)"
    BEGIN
        MENUITEM "关于(&A)...",                  ID_HELP_ABOUT
    END
END

/* ============================================================
 * 加速键表
 *
 * NOINVERT 让菜单不会被加速键触发时反白闪一下
 * VIRTKEY  对应 VK_* 虚拟键码
 * ============================================================ */
IDR_ACCELERATOR ACCELERATORS
BEGIN
    "N",        ID_FILE_NEW,        VIRTKEY, CONTROL, NOINVERT
    "W",        ID_FILE_CLOSE_TAB,  VIRTKEY, CONTROL, NOINVERT
    VK_TAB,     ID_TAB_NEXT,        VIRTKEY, CONTROL, NOINVERT
    VK_TAB,     ID_TAB_PREV,        VIRTKEY, CONTROL, SHIFT, NOINVERT
    VK_F2,      ID_TAB_RENAME,      VIRTKEY, NOINVERT
END
